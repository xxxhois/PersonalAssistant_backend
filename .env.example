# LLM Configuration
LLM_PROVIDER=openai  # openai | deepseek | openrouter
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
LLM_TEMPERATURE=0.7

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=personal_assistant
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_assistant

# Vector Database (ChromaDB)
MEMORY_BACKEND=chroma  # chroma | in_memory
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION=memories

# Redis (Cache & Outbox)
REDIS_URL=redis://localhost:6379/0

# Application Configuration
APP_NAME="Personal Assistant Backend"
DEBUG=true
SECRET_KEY=generate-a-secure-secret-key-here
API_V1_STR=/api/v1
ALLOW_ORIGINS=["http://localhost:3000"]

# Monitoring & Logs
LOG_LEVEL=INFO
